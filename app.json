{
  "expo": {
    "name": "tifossi",
    "slug": "tifossi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tifossi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tiffosi.store",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:tifossi.app",
        "applinks:auth.tifossi.app",
        "applinks:pay.tifossi.app",
        "applinks:appleid.apple.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "extra": {
      "privacyPolicyUrl": "https://tifossi-strapi-backend.onrender.com/privacy.html"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://tifossi.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-video",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.123456789012-placeholder" // TODO: Replace with actual reversed client ID from GoogleService-Info.plist (REVERSED_CLIENT_ID key). Also update webClientId in firebaseAuth.ts
        }
      ],
      [
        "expo-apple-authentication",
        {
          "appleTeamId": "PLACEHOLDER_TEAM_ID" // TODO: Replace with actual Apple Team ID from Apple Developer account
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "app.tiffosi.store",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tifossi.app"
            },
            {
              "scheme": "https",
              "host": "auth.tifossi.app"
            },
            {
              "scheme": "https",
              "host": "pay.tifossi.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "tifossi"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    }
  }
}
