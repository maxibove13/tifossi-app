{
  "expo": {
    "name": "tifossi",
    "slug": "tifossi",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tifossi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tiffosi.store",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:auth.tifossi.app",
        "applinks:pay.tifossi.app"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "extra": {
      "privacyPolicyUrl": "https://tifossi-strapi-backend.onrender.com/privacy.html",
      "router": {
        "origin": "https://tifossi.app"
      },
      "eas": {
        "projectId": "c8c7c9d4-6fcd-496f-b840-36f8e2cea4c8"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-router",
        {
          "origin": "https://tifossi.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-video",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.351272853841-24k61p1j3a3cas6ejhb3t9nuhjclp9uu"
        }
      ],
      [
        "expo-apple-authentication",
        {
          "appleTeamId": "KM7UAMA5MF"
        }
      ],
      "./plugins/withModularHeaders.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "app.tiffosi.store",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "auth.tifossi.app"
            },
            {
              "scheme": "https",
              "host": "pay.tifossi.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "owner": "maxibove13",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c8c7c9d4-6fcd-496f-b840-36f8e2cea4c8"
    }
  }
}
