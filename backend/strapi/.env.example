# Strapi Configuration
HOST=0.0.0.0
PORT=1337
APP_KEYS=your-app-keys-here
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# Database
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# MercadoPago Configuration
MP_ACCESS_TOKEN=your-mercadopago-access-token
MP_PUBLIC_KEY=your-mercadopago-public-key
MP_WEBHOOK_SECRET=your-webhook-secret

# MercadoPago Sandbox (for testing)
MP_ACCESS_TOKEN_SANDBOX=TEST-1234567890-123456-your-sandbox-token
MP_PUBLIC_KEY_SANDBOX=TEST-your-public-key-sandbox

# Application Configuration
API_BASE_URL=http://localhost:1337
APP_SCHEME=tifossi
FRONTEND_URL=https://tifossi.app

# Email Configuration (optional)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@tifossi.app

# File Upload - Cloudinary Configuration
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# Alternative: AWS S3 (if not using Cloudinary)
# UPLOAD_PROVIDER=aws-s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET=tifossi-uploads

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your-analytics-key