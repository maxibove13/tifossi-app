# Strapi Configuration
HOST=0.0.0.0
PORT=1337
APP_KEYS=your-app-keys-here
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# Database
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# MercadoPago Configuration
# Note: Backend code uses MP_* prefix for environment variables
# The code automatically selects test or production credentials based on NODE_ENV

# Production credentials (use after business verification)
MP_ACCESS_TOKEN=APP-your-production-access-token
MP_PUBLIC_KEY=APP-your-production-public-key

# Test credentials (for development and testing)
MP_TEST_ACCESS_TOKEN=TEST-1234567890-123456-your-test-token
MP_TEST_PUBLIC_KEY=TEST-your-test-public-key

# Webhook configuration (same secret for test and production)
MP_WEBHOOK_SECRET=your-webhook-secret-from-mercadopago-dashboard
WEBHOOK_URL=https://your-backend-url.onrender.com/webhooks/mercadopago

# Application Configuration
API_BASE_URL=http://localhost:1337
APP_SCHEME=tifossi
FRONTEND_URL=https://tifossi.app

# Email Configuration (OPTIONAL - disabled by default)
# Email plugin only loads when SMTP_HOST is configured
# Required for: password reset emails, order confirmations
# See ADMIN_AUTH.md for setup guide
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=info@tifossi.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=info@tifossi.com
# EMAIL_REPLY_TO=support@tifossi.com

# File Upload - Cloudinary Configuration
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# Alternative: AWS S3 (if not using Cloudinary)
# UPLOAD_PROVIDER=aws-s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET=tifossi-uploads

# Authentication Rate Limiting (brute-force protection)
# Protects login/signup/password-reset endpoints from abuse
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_DURATION=60000

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your-analytics-key

# Firebase Admin SDK Configuration (REQUIRED for authentication)
# The backend uses Firebase Admin to verify user tokens from the mobile app
# Choose ONE of the following options:

# Option 1 (Recommended): Full service account JSON
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"}

# Option 2: Individual fields (if not using full JSON above)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Optional: Path to service account JSON file (if using file instead of env vars)
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json