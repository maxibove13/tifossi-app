{
  "name": "tifossi-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Tifossi Expo Backend API",
  "scripts": {
    "build": "strapi build",
    "postbuild": "node dist/scripts/sync-compiled-config.js",
    "develop": "strapi develop",
    "start": "strapi start",
    "start:debug": "node scripts/test-db-connection.js && strapi start",
    "strapi": "strapi",
    "seed": "strapi import",
    "seed:render": "node scripts/import-seed-to-render.js",
    "export": "strapi export",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js --watchman=false",
    "test:ci": "jest --config jest.config.js --ci --coverage --maxWorkers=2 --watchman=false",
    "test:watch": "jest --config jest.config.js --watch --watchman=false",
    "test:coverage": "jest --config jest.config.js --coverage --watchman=false",
    "test:webhooks": "jest --config jest.config.js --testMatch='**/tests/mercadopago-webhook.test.js' --watchman=false",
    "test:payment": "jest --config jest.config.js --testMatch='**/tests/mercadopago*.test.js' --watchman=false"
  },
  "dependencies": {
    "@strapi/plugin-cloud": "^5.29.0",
    "@strapi/plugin-documentation": "^5.29.0",
    "@strapi/plugin-graphql": "^5.29.0",
    "@strapi/plugin-users-permissions": "^5.29.0",
    "@strapi/provider-upload-cloudinary": "^5.29.0",
    "@strapi/strapi": "^5.29.0",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.5.0",
    "helmet": "^7.1.0",
    "mercadopago": "^2.9.0",
    "pg": "^8.11.3",
    "pg-connection-string": "^2.6.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/node": "^20.11.19",
    "babel-jest": "^29.7.0",
    "formdata-node": "^6.0.3",
    "jest": "^29.7.0",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0 <=20.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "0053b374-53bd-4c88-9791-54525015d81f"
  }
}
