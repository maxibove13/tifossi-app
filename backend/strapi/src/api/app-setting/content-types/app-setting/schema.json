{
  "kind": "singleType",
  "collectionName": "app_settings",
  "info": {
    "singularName": "app-setting",
    "pluralName": "app-settings",
    "displayName": "App Settings",
    "description": "Global app configuration managed by admins"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "supportPhoneNumber": {
      "type": "string",
      "required": true,
      "default": "+59899000000"
    },
    "supportEmail": {
      "type": "email"
    },
    "businessName": {
      "type": "string",
      "default": "Tifossi"
    },
    "shippingCostDelivery": {
      "type": "decimal",
      "required": true,
      "default": 200,
      "min": 0
    },
    "splashVideo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    }
  }
}
