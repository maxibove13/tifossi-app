{
  "collectionName": "components_product_product_colors",
  "info": {
    "displayName": "Product Color",
    "description": "Product color variant with hex code and name"
  },
  "options": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 50
    },
    "hexCode": {
      "type": "string",
      "required": true,
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
