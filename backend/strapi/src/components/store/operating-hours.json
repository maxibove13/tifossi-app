{
  "collectionName": "components_store_operating_hours",
  "info": {
    "displayName": "Operating Hours",
    "description": "Store operating hours for each day of the week"
  },
  "options": {},
  "attributes": {
    "dayOfWeek": {
      "type": "enumeration",
      "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
      "required": true
    },
    "openTime": {
      "type": "string",
      "required": false,
      "regex": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
    },
    "closeTime": {
      "type": "string",
      "required": false,
      "regex": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
    },
    "isClosed": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string",
      "required": false,
      "maxLength": 255
    }
  }
}