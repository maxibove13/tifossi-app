{
  "cli": {
    "version": ">= 0.60.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:1337"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://tifossi-strapi-backend.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "macos-sequoia-15.6-xcode-26.0"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://tifossi-strapi-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "maximilianobove@gmail.com",
        "ascAppId": "6755054701",
        "appleTeamId": "KM7UAMA5MF"
      },
      "android": {
        "serviceAccountKeyPath": "./service-account-key.json",
        "track": "production"
      }
    }
  }
}
