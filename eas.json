{
  "cli": {
    "version": ">= 0.60.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:1337"
      },
      "ios": {
        "simulator": true,
        "bundleIdentifier": "com.tifossi.dev",
        "entitlements": {
          "com.apple.developer.applesignin": ["Default"]
        }
      },
      "android": {
        "gradleCommand": ":app:assembleDebug",
        "applicationId": "com.tifossi.dev"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://tifossi-strapi-backend.onrender.com"
      },
      "ios": {
        "entitlements": {
          "com.apple.developer.applesignin": ["Default"]
        }
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://tifossi-strapi-backend.onrender.com"
      },
      "ios": {
        "bundleIdentifier": "com.tifossi.app",
        "entitlements": {
          "com.apple.developer.applesignin": ["Default"]
        }
      },
      "android": {
        "applicationId": "com.tifossi.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./service-account-key.json",
        "track": "production"
      }
    }
  }
}
