# Tifossi Backend Docker Ignore File
# Files and directories to exclude from Docker build context

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm/

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output/

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env*
!.env.example
!.env.template

# parcel-bundler cache (https://parceljs.org/)
.cache/
.parcel-cache/

# Next.js build output
.next/

# Nuxt.js build / generate output
.nuxt/
dist/

# Gatsby files
.cache/
public/

# Storybook build outputs
.out/
.storybook-out/

# Temporary folders
tmp/
temp/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*
.docker/
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Documentation
README.md
CHANGELOG.md
docs/
*.md

# Test files
__tests__/
tests/
test/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
jest.config.js
.jest/

# Build artifacts
build/
dist/
lib/

# Strapi specific
.strapi-updater.json
.tmp/
build/
exports/

# Database
*.sqlite
*.db

# Uploads (handled by volumes)
public/uploads/*
!public/uploads/.gitkeep

# Infrastructure files
infrastructure/
scripts/
migrations/

# Backup files
*.bak
*.backup

# SSL certificates
*.key
*.crt
*.pem

# Local configuration
config/local.js
config/production.js
config/staging.js

# Monitoring and debugging
.nyc_output/
coverage/
debug.log

# Package managers
.pnp.*
.pnp/
.yarn/

# Runtime
.strapi/

# Local development
.local/
.cache/